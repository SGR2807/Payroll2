# Payroll Application Environment Variables

# Config Server
CONFIG_SERVER_PORT=8071

# Eureka Server
EUREKA_SERVER_PORT=8070

# Gateway Server
GATEWAY_SERVER_PORT=8072

# Employee Service
EMPLOYEE_SERVICE_PORT=8090

# Leave Service
LEAVE_SERVICE_PORT=8080

# Payroll Service
PAYROLL_SERVICE_PORT=9001

# Keycloak
KEYCLOAK_PORT=7080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Memory Limits (in MB)
MEMORY_LIMIT=700m

# Spring Profiles
SPRING_PROFILES_ACTIVE=default

# Docker Image Version
IMAGE_VERSION=1.0.0

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=payroll
POSTGRES_PASSWORD=payroll123

# Docker Registry
DOCKER_REGISTRY=shaileshrathod28
